	url = https://github.com/smartcontractkit/chainlink-evm
[submodule "lib/zk-kit"]
	path = lib/zk-kit
	url = https://github.com/privacy-scaling-explorations/zk-kit
[submodule "lib/semaphore"]
	path = lib/semaphore
	url = https://github.com/semaphore-protocol/semaphore
